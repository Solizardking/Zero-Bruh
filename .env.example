# Safe placeholders only. Put real values in .env.local, never in git.
#
# Web console: open Connectors → "🔑 API Keys" popup to fill these interactively.
# POST /api/keys writes .env.local (localhost only; values never returned).

# Local/cloud key vault gates for web/backend.
CLAWDBOT_VAULT_ENABLED=0
CLAWDBOT_VAULT_ALLOWED_IPS=127.0.0.1
CLAWDBOT_VAULT_TOKEN=replace-with-a-long-random-token

# Optional when serving through a trusted reverse proxy.
CLAWDBOT_TRUST_PROXY_HEADERS=0

# Direct LLM providers — take priority over the free zkrouter default when set.
XAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Skill / agent catalog roots (path-relative; no host-specific defaults required)
# Bundled open Robinhood/EVM pack lives at ./skills — anyone can use it.
# CLAWDBOT_SKILLS_DIR=./skills
# CLAWDBOT_MERGE_BUNDLED_SKILLS=1
# CLAWDBOT_AGENTS_DIR=
# CLAWDBOT_ZK_PRIMITIVES_DIR=./zk-primitives

# Solana / market data
HELIUS_API_KEY=
BIRDEYE_API_KEY=
JUPITER_API_KEY=
ASTER_API_KEY=
ASTER_API_SECRET=

# Robinhood Chain (4663) — required for omni launch / deploy / Pons + Uniswap trade
# Free PRO key: https://dev.blockscout.com  (format: proapi_…)
# Public RPC is a read-only fallback when RH_RPC_URL is unset — not deploy-safe.
BLOCKSCOUT_API_KEY=
RH_RPC_URL=
# Optional overrides (defaults: chain 4663, https://api.blockscout.com)
# RH_CHAIN_ID=4663
# BLOCKSCOUT_BASE_URL=https://api.blockscout.com

# Channels / browsers / compute
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
BROWSERUSE_API_KEY=
KERNEL_API_KEY=
E2B_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
